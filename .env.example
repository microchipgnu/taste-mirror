# Set MOCK_VIATOR=true to use the in-memory mock client (no API key needed).
# Set MOCK_VIATOR=false (or leave unset) to hit the real Viator Partner API.
MOCK_VIATOR=true

# Viator Partner API credentials — get from your Viator mentor at the hackathon.
VIATOR_API_KEY=

# Base URL — sandbox by default. Switch to https://api.viator.com/partner for production.
VIATOR_BASE_URL=https://api.sandbox.viator.com/partner

# Affiliate identifiers. Live mode does not need these — Viator returns
# productUrl with attribution baked in. They are only used by the mock
# client and as a fallback when productUrl is missing.
VIATOR_PARTNER_ID=PLACEHOLDER_PID
VIATOR_MCID=42383

# Optional: campaign tracking ID. Sent as ?campaign-value= on Viator calls;
# Viator appends it to productUrl so you can break out attribution per
# campaign in the Viator Partner Platform reports.
# VIATOR_CAMPAIGN=taste-mirror
